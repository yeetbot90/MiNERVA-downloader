{
  "name": "minerva-downloader",
  "version": "4.0.3",
  "description": "A desktop app to browse, filter, and download from MiNERVA.",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/style.css && electron .",
    "build:all": "npm run build:css && electron-builder --publish never",
    "build:win": "npm run build:css && electron-builder --win --publish never",
    "build:win:portable": "npm run build:css && electron-builder --win portable --publish never",
    "build:win:folder": "npm run build:css && electron-builder --win --dir --publish never",
    "build:mac": "npm run build:css && electron-builder --mac --publish never",
    "build:linux": "npm run build:css && electron-builder --linux --publish never",
    "build:css": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/style.css --minify"
  },
  "keywords": [],
  "author": "Brad Evans",
  "license": "ISC",
  "dependencies": {
    "@kldzj/stream-throttle": "^1.1.1",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "electron-log": "^5.1.5",
    "electron-store": "^8.2.0",
    "p-limit": "^7.2.0",
    "sql.js": "^1.14.1",
    "webtorrent": "^2.8.5",
    "yauzl": "^3.2.0",
    "yauzl-promise": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^3.4.3"
  },
  "build": {
    "appId": "org.minerva.downloader",
    "productName": "MiNERVA Downloader",
    "files": [
      "**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
